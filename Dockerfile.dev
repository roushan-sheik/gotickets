# ==============================================================================
# Development Image
# Installs air for hot reload. Source code is mounted as a volume at runtime,
# so this image does NOT copy source — only installs tooling.
# ==============================================================================
FROM golang:1.23-alpine

ENV GOTOOLCHAIN=auto

RUN apk add --no-cache git

# Install air — the live-reload tool for Go
RUN go install github.com/air-verse/air@latest

WORKDIR /app

# Pre-download modules for faster first startup.
# Source is mounted as a volume, not baked into the image.
COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod \
    go mod download

EXPOSE 5000

CMD ["air", "-c", ".air.toml"]
